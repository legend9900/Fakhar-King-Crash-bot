// /logout
bot.command('logout', async (ctx) => {
    if (!waConnected) {
        return ctx.reply('ℹ️ WhatsApp already disconnected.');
    }
    
    stopAttack(ctx);
    
    try {
        await waSocket.logout();
        waConnected = false;
        await ctx.reply('✅ *WhatsApp logged out successfully!*', { parse_mode: 'Markdown' });
    } catch (err) {
        ctx.reply(`❌ Error logging out: ${err.message}`);
    }
});

// /adduser - Owner can add users
bot.command('adduser', async (ctx) => {
    if (ctx.from.id !== OWNER_ID) {
        return ctx.reply('⛔ Only bot owner can add users.');
    }
    const args = ctx.message.text.split(' ');
    if (args.length < 2) {
        return ctx.reply('❌ Usage: /adduser USER_ID');
    }
    const userId = parseInt(args[1]);
    if (!allowedUsers.includes(userId)) {
        allowedUsers.push(userId);
    }
    await ctx.reply(`✅ User ${userId} added to allowed list.`);
});

