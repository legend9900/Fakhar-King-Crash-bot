// /pair - WhatsApp connect karo
bot.command('pair', async (ctx) => {
    const args = ctx.message.text.split(' ');
    if (args.length < 2) {
        return ctx.reply('❌ Usage: /pair 91XXXXXXXXXX\n\nCountry code ke saath number do.');
    }
    
    let phoneNumber = args[1].replace(/[^0-9]/g, '');
    
    if (phoneNumber.startsWith('0')) {
        phoneNumber = phoneNumber.substring(1);
    }
    
    if (phoneNumber.length < 10) {
        return ctx.reply('❌ Invalid number. Country code ke saath pura number do.\nExample: /pair 919XXXXXXXXX');
    }
    
    await ctx.reply(`⏳ *Generating pairing code...*\n\nNumber: +${phoneNumber}\n\nPlease wait 10-15 seconds...`,
        { parse_mode: 'Markdown' }
    );
    
    try {
        const code = await getPairingCode(phoneNumber);
        
        if (code) {
            await ctx.replyWithMarkdown(
                `✅ *Pairing Code Generated!*\n\n` +
                `📱 Code: \`${code}\`\n\n` +
                `📌 *Steps:*\n` +
                `1. Open WhatsApp on your phone\n` +
                `2. Go to *Settings → Linked Devices*\n` +
                `3. Tap *Link a Device*\n` +
                `4. Enter this code: \`${code}\`\n\n` +
                `⏳ Bot will auto-confirm when connected.`
            );
        } else {
            ctx.reply('❌ Failed to generate code. Bot restart ho raha hai, 30s baad /pair dobara karo.');
        }
    } catch (err) {
        ctx.reply(`❌ Error: ${err.message}`);
    }
});

