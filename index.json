const DEFAULT_COUNT = config.DEFAULT_COUNT || 80;
const FLOOD_COUNT = config.FLOOD_COUNT || 200;
const ALLOW_ALL_USERS = config.ALLOW_ALL_USERS || false;

// Sessions folder
